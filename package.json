{
  "name": "sxl-resolver",
  "displayName": "SXL Resolver",
  "publisher": "andySobolev",
  "license": "Proprietary",
  "description": "Design token intellisense: resolved values, visual previews, inheritance chains. Works in JSON and CSS var().",
  "version": "2.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndySobolev/JsonHint-TS"
  },
  "bugs": {
    "url": "https://github.com/AndySobolev/JsonHint-TS/issues"
  },
  "homepage": "https://github.com/AndySobolev/JsonHint-TS/blob/main/README.md",
  "scripts": {
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "compile": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "build-all": "npm install && npm run compile && npm run build && npx @vscode/vsce package",
    "release": "npm run build-all && npx @vscode/vsce publish"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "SXL Resolver",
      "properties": {
        "sxlResolver.tokenPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "tokens"
          ],
          "description": "Paths to token folders (relative to workspace root). Multiple folders are merged."
        },
        "sxlResolver.showIcons": {
          "type": "boolean",
          "default": true,
          "description": "Show type icons in hover tooltips."
        },
        "sxlResolver.maxChainLength": {
          "type": "number",
          "default": 5,
          "description": "Maximum chain depth displayed in hover tooltips."
        },
        "sxlResolver.maxSuggestions": {
          "type": "number",
          "default": 300,
          "description": "Limit number of completion suggestions."
        },
        "sxlResolver.allowNoDollar": {
          "type": "boolean",
          "default": true,
          "description": "Recognize tokens defined without a leading '$' (e.g. 'value' instead of '$value')."
        },
        "sxlResolver.cssVariablePrefix": {
          "type": "string",
          "default": "--",
          "description": "Prefix used for CSS variable reverse mapping (e.g. '--' for var(--token-name))."
        },
        "sxlResolver.enableCssHover": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover tooltips for var(--token-name) in CSS/SCSS/TSX files."
        }
      }
    },
    "commands": [
      {
        "command": "sxlResolver.revealToken",
        "title": "SXL Resolver: Reveal Token in File"
      },
      {
        "command": "sxlResolver.forceRefresh",
        "title": "SXL Resolver: Force Refresh Tokens"
      }
    ]
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "mathjs": "^12.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^10.0.3",
    "source-map-loader": "^5.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  }
}